{
  "name": "@gcorevideo/rtckit",
  "version": "0.89.28",
  "private": false,
  "description": "A WebRTC client for Gcore Streaming Platform",
  "license": "Apache-2.0",
  "types": "lib/index.d.ts",
  "main": "dist/index.esm.js",
  "files": [
    "lib"
  ],
  "keywords": [
    "video streaming"
  ],
  "type": "module",
  "scripts": {
    "build": "npm run build:ts && npm run build:bundle",
    "build:ts": "tsc",
    "build:bundle": "rollup -c",
    "docs": "npm run docs:extract && npm run docs:build",
    "docs:extract": "api-extractor run --local --verbose",
    "docs:build": "api-documenter markdown --input-folder=temp --output-folder=docs/api",
    "format": "prettier --write src/",
    "lint": "oxlint -c ../../.oxlintrc.json --tsconfig=./tsconfig.json --fix --ignore-path=../../.gitignore src",
    "ship": "git diff . > ./drop/build-$(cat package.json|jq -r '.version')-`date +%s`.diff && npm run build && npm publish --access public",
    "test": "vitest --environment=jsdom run",
    "test:watch": "vitest --environment=jsdom watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/G-Core/gcore-webrtc-sdk-js.git"
  },
  "author": "Gcore",
  "bugs": {
    "url": "https://github.com/G-Core/gcore-webrtc-sdk-js/issues"
  },
  "homepage": "https://github.com/G-Core/gcore-webrtc-sdk-js#readme",
  "dependencies": {
    "@gcorevideo/utils": "^0.7.1",
    "event-lite": "^1.0.0",
    "sdp-transform": "^2.14.2"
  },
  "devDependencies": {
    "@microsoft/api-documenter": "^7.26.8",
    "@microsoft/api-extractor": "^7.47.5",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@sentry/types": "^10.51.0",
    "@sinonjs/fake-timers": "^14.0.0",
    "@types/debug": "^4.1.12",
    "@types/sdp-transform": "^2.4.9",
    "@types/sinonjs__fake-timers": "^8.1.5",
    "jsdom": "^29.1.1",
    "oxlint": "^1.7.0",
    "prettier": "^3.3.3",
    "rollup": "^4.19.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
